# Future Hause — Environment Variables

# ─────────────────────────────────────────────
# Reddit API (Required for Reddit ingestion)
# ─────────────────────────────────────────────
# Create an app at https://www.reddit.com/prefs/apps
# Select "script" type for personal use
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=FutureHause/0.1

# ─────────────────────────────────────────────
# Twitter/X API (Optional, feature-flagged)
# ─────────────────────────────────────────────
# Requires Twitter Developer account with API v2 access
# Set TWITTER_ENABLED=true to enable the connector
TWITTER_ENABLED=false
TWITTER_BEARER_TOKEN=

# ─────────────────────────────────────────────
# News Feed Settings (No API key required)
# ─────────────────────────────────────────────
# Timeout for RSS feed fetches (seconds)
NEWS_FETCH_TIMEOUT=10

# ─────────────────────────────────────────────
# Ollama (Local LLM)
# ─────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434

# ─────────────────────────────────────────────
# Freshdesk (Future use)
# ─────────────────────────────────────────────
FRESHDESK_API_KEY=
